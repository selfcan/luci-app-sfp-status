msgid ""
msgstr ""
"Language: zh_Hans\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Plural-Forms: nplurals=1; plural=0;\n"

msgid "Adaptive Fan Profile"
msgstr "自适应风扇画像"

msgid "BPI-R4 routers usually benefit from a slightly lower smart start temperature when Wi-Fi or NSS load ramps up quickly."
msgstr "BPI-R4 在 Wi-Fi 或 NSS 负载快速爬升时，通常更适合略低的智能启动温度。"

msgid "BPI-R4 tuned layout with live CPU temperature, PWM duty, tachometer feedback and three operating modes."
msgstr "已针对 BPI-R4 优化布局，实时展示 CPU 温度、PWM 占空比、转速反馈和三种工作模式。"

msgid "CPU temperature"
msgstr "CPU 温度"

msgid "Ceiling not exposed"
msgstr "未暴露上限"

msgid "Configure Smart, Turbo and Manual fan profiles for pwm-fan capable boards such as the BPI-R4. The live panel reads CPU temperature, PWM duty and tachometer feedback over ubus."
msgstr "为 BPI-R4 等支持 pwm-fan 的设备配置智能、狂暴和手动风扇模式。实时面板会通过 ubus 读取 CPU 温度、PWM 占空比和转速反馈。"

msgid "Control mode"
msgstr "控制模式"

msgid "Cooling active"
msgstr "正在散热"

msgid "Current PWM duty"
msgstr "当前 PWM 占空比"

msgid "Current config"
msgstr "当前配置"

msgid "Current device"
msgstr "当前设备"

msgid "Current fan duty"
msgstr "当前风扇占空比"

msgid "Current temperature"
msgstr "当前温度"

msgid "Current temperature is already above the smart start threshold. Save carefully to avoid sudden fan jumps."
msgstr "当前温度已高于智能启动阈值，保存时请留意避免风扇突跳。"

msgid "Disabled"
msgstr "未启用"

msgid "Duty target in percent for Manual mode. 0 turns the fan off, 100 drives the maximum PWM value."
msgstr "手动模式下的目标占空比，单位百分比。0 表示关闭风扇，100 表示输出最大 PWM。"

msgid "Enable fan service"
msgstr "启用风扇服务"

msgid "Enable the service and Save & Apply to start the fan daemon."
msgstr "启用服务并点击“保存并应用”后，风扇守护进程才会启动。"

msgid "Enabled"
msgstr "启用"

msgid "Enabled in UCI"
msgstr "UCI 启用状态"

msgid "Fan Control"
msgstr "风扇控制"

msgid "Fan daemon loop interval in seconds. Lower values react faster, higher values reduce churn."
msgstr "风扇守护进程循环间隔，单位秒。数值越小响应越快，数值越大抖动越少。"

msgid "Fan speed"
msgstr "风扇转速"

msgid "Fan start temperature"
msgstr "风扇启动温度"

msgid "Fan stop temperature"
msgstr "风扇停止温度"

msgid "Live Cooling Dashboard"
msgstr "实时散热仪表盘"

msgid "Live OpenWrt cooling dashboard with smart, manual and turbo profiles when the target hardware exposes pwm-fan telemetry."
msgstr "当目标硬件暴露 pwm-fan 遥测时，此界面可提供 OpenWrt 实时散热面板以及智能、手动、狂暴三种配置。"

msgid "Loaded into the form"
msgstr "已填入表单"

msgid "Manual"
msgstr "手动"

msgid "Manual PWM target"
msgstr "手动 PWM 目标"

msgid "Manual mode"
msgstr "手动模式"

msgid "Manual mode applies the selected duty target after Save & Apply."
msgstr "手动模式会在“保存并应用”后应用所选占空比。"

msgid "Manual target"
msgstr "手动目标"

msgid "Mode target"
msgstr "模式目标"

msgid "Modulating"
msgstr "调速中"

msgid "Monitoring state"
msgstr "监控状态"

msgid "Next trip ceiling"
msgstr "下一触发点上限"

msgid "Not available"
msgstr "不可用"

msgid "Off temperature should stay at least 3 C below the start threshold for stable smart mode modulation."
msgstr "为保持智能调速稳定，停止温度至少应比启动阈值低 3 C。"

msgid "Operating profiles"
msgstr "工作模式"

msgid "Polling interval"
msgstr "轮询间隔"

msgid "Profile Settings"
msgstr "模式设置"

msgid "Runtime fan speed"
msgstr "实时风扇转速"

msgid "Runtime insight"
msgstr "运行洞察"

msgid "Save & Apply below to persist changes."
msgstr "需要在下方点击“保存并应用”后才会持久生效。"

msgid "Sensor unavailable"
msgstr "传感器不可用"

msgid "Smart"
msgstr "智能"

msgid "Smart mode"
msgstr "智能模式"

msgid "Smart mode follows CPU temperature and ramps the pwm-fan duty automatically."
msgstr "智能模式会根据 CPU 温度自动调节 pwm-fan 占空比。"

msgid "Smart start threshold"
msgstr "智能启动阈值"

msgid "Smart start threshold must be a valid integer."
msgstr "智能启动阈值必须是有效整数。"

msgid "Smart start threshold must be greater than the stop threshold."
msgstr "智能启动阈值必须高于停止阈值。"

msgid "Smart stop threshold"
msgstr "智能停止阈值"

msgid "Smart stop threshold must be a valid integer."
msgstr "智能停止阈值必须是有效整数。"

msgid "Smart stop threshold must stay below the start threshold."
msgstr "智能停止阈值必须低于启动阈值。"

msgid "Standby"
msgstr "待机"

msgid "Start the fan daemon on Save & Apply. Smart mode follows CPU temperature, Turbo holds 100%, and Manual applies the slider target on pwm-fan capable boards."
msgstr "点击“保存并应用”后启动风扇守护进程。智能模式跟随 CPU 温度，狂暴模式固定 100%，手动模式会在支持 pwm-fan 的设备上应用滑条目标。"

msgid "Temperature in Celsius where Smart mode drops back to zero duty. Keep it at least 3 C below the start threshold."
msgstr "智能模式降回 0 占空比的温度，单位摄氏度。建议至少比启动阈值低 3 C。"

msgid "Temperature in Celsius where Smart mode ramps the fan into a clearly audible cooling state."
msgstr "智能模式进入明显散热状态的温度，单位摄氏度。"

msgid "Thermal ladder"
msgstr "温控阶梯"

msgid "This device does not currently expose a writable pwm-fan hwmon interface or an active writable fan trip point."
msgstr "当前设备尚未暴露可写的 pwm-fan hwmon 接口，也没有可写的活动风扇热控触发点。"

msgid "Threshold reached"
msgstr "已达到阈值"

msgid "Turbo"
msgstr "狂暴"

msgid "Turbo and Manual modes require pwm-fan hwmon support on the target board."
msgstr "狂暴模式和手动模式需要目标设备提供 pwm-fan hwmon 支持。"

msgid "Turbo and Manual require pwm-fan hwmon support. Smart mode also falls back to writable thermal trip control on older targets."
msgstr "狂暴和手动模式需要 pwm-fan hwmon 支持。对于较老的目标，智能模式仍可回退到可写的热控触发点控制。"

msgid "Turbo mode"
msgstr "狂暴模式"

msgid "Turbo mode keeps the fan at maximum duty after Save & Apply."
msgstr "狂暴模式在“保存并应用”后会让风扇保持最大占空比。"

msgid "Unavailable"
msgstr "不可用"

msgid "Use these shortcuts to load Turbo, Smart or Manual targets into the form below before Save & Apply."
msgstr "使用这些快捷按钮可先将狂暴、智能或手动目标写入下方表单，再执行“保存并应用”。"

msgid "Waiting for telemetry..."
msgstr "正在等待遥测数据..."

msgid "before next trip"
msgstr "到下一触发点前"

msgid "to start"
msgstr "后启动"
