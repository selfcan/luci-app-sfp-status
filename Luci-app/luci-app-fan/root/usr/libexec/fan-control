#!/bin/sh
# author: jjm2473

SAVE=/tmp/run/fanTP
PWM_SAVE=/tmp/run/fanPWM
ACTION=$1
shift

SMART_MIN_MILLI=30000
SMART_MAX_MILLI=60000
SMART_MAX_RPM=3000
SMART_MAX_RPM_MIN=500
SMART_MAX_RPM_MAX=10000

ensure_cache_dir() {
    mkdir -p "${SAVE%/*}"
}

read_trimmed() {
    [ -r "$1" ] || return 1
    value=$(cat "$1" 2>/dev/null) || return 1
    printf '%s' "$value" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

read_number() {
    value=$(read_trimmed "$1") || return 1
    [ -n "$value" ] || return 1
    value=$(printf '%s\n' "$value" | sed -n 's/[^0-9]*\([0-9][0-9]*\).*/\1/p' | head -n1)
    [ -n "$value" ] || return 1
    printf '%s\n' "$value"
}

is_uint() {
    case "$1" in
        ''|*[!0-9]*)
            return 1
            ;;
        *)
            return 0
            ;;
    esac
}

clamp_uint() {
    value=$1
    minimum=$2
    maximum=$3

    [ "$value" -lt "$minimum" ] && value=$minimum
    [ "$value" -gt "$maximum" ] && value=$maximum
    printf '%s\n' "$value"
}

percent_to_raw() {
    awk -v value="$1" 'BEGIN {
        raw = int((value * 255 / 100) + 0.5)
        if (raw < 0)
            raw = 0
        else if (raw > 255)
            raw = 255
        printf "%d", raw
    }'
}

estimate_rpm_from_raw() {
    awk -v raw="$1" -v max_rpm="${2:-$SMART_MAX_RPM}" 'BEGIN {
        if (raw == "" || raw < 0)
            raw = 0
        if (raw > 255)
            raw = 255
        printf "%d", int((raw * max_rpm / 255) + 0.5)
    }'
}

read_uci_uint() {
    value=$(uci -q get "luci-fan.@luci-fan[0].$1" 2>/dev/null)
    is_uint "$value" || return 1
    printf '%s\n' "$value"
}

parse_celsius_to_milli() {
    awk -v value="$1" 'BEGIN {
        if (value == "" || value !~ /^([0-9]+([.][0-9]+)?|[.][0-9]+)$/)
            exit 1

        milli = int((value * 1000) + 0.5)
        if (milli < 0)
            exit 1

        printf "%d", milli
    }'
}

read_uci_temp_milli() {
    value=$(uci -q get "luci-fan.@luci-fan[0].$1" 2>/dev/null)
    [ -n "$value" ] || return 1
    parse_celsius_to_milli "$value"
}

resolve_smart_window_milli() {
    on_milli=$(read_uci_temp_milli on_temp) || on_milli=$SMART_MAX_MILLI
    off_milli=$(read_uci_temp_milli off_temp) || off_milli=$SMART_MIN_MILLI

    on_milli=$(clamp_uint "$on_milli" 100 150000)
    off_milli=$(clamp_uint "$off_milli" 0 149900)

    if [ "$on_milli" -le "$off_milli" ]; then
        if [ "$off_milli" -ge 149900 ]; then
            off_milli=149800
            on_milli=149900
        else
            on_milli=$((off_milli + 100))
        fi
    fi

    SMART_WINDOW_ON_MILLI=$on_milli
    SMART_WINDOW_OFF_MILLI=$off_milli
}

resolve_max_rpm() {
    max_rpm=$(read_uci_uint max_rpm) || max_rpm=$SMART_MAX_RPM
    max_rpm=$(clamp_uint "$max_rpm" "$SMART_MAX_RPM_MIN" "$SMART_MAX_RPM_MAX")
    EFFECTIVE_MAX_RPM=$max_rpm
}

read_uci_mode() {
    value=$(uci -q get 'luci-fan.@luci-fan[0].mode' 2>/dev/null)

    case "$value" in
        turbo|smart|manual)
            printf '%s\n' "$value"
            ;;
        *)
            printf '%s\n' 'smart'
            ;;
    esac
}

resolve_pwm_rpm_path() {
    candidate=
    fallback=
    hwmon=
    pwm_device=
    hwmon_device=
    pwm_parent=

    PWM_RPM_PATH=''

    candidate=$(find_rpm_candidate_in_dir "$PWM_HWMON") || candidate=''
    if [ -n "$candidate" ]; then
        PWM_RPM_PATH="$candidate"
        return 0
    fi

    pwm_device=$(readlink -f "$PWM_HWMON/device" 2>/dev/null) || pwm_device=''
    pwm_parent=$(dirname "$pwm_device" 2>/dev/null)

    for hwmon in "$pwm_device" "$pwm_device"/hwmon/hwmon* "$pwm_parent"/hwmon/hwmon*; do
        candidate=$(find_rpm_candidate_in_dir "$hwmon") || candidate=''
        if [ -n "$candidate" ]; then
            PWM_RPM_PATH="$candidate"
            return 0
        fi
    done

    for hwmon in /sys/class/hwmon/hwmon*; do
        [ -d "$hwmon" ] || continue
        [ "$hwmon" = "$PWM_HWMON" ] && continue

        candidate=$(find_rpm_candidate_in_dir "$hwmon") || candidate=''
        [ -n "$candidate" ] || continue

        hwmon_device=$(readlink -f "$hwmon/device" 2>/dev/null) || hwmon_device=''

        if [ -n "$pwm_device" ] && [ -n "$hwmon_device" ]; then
            case "$hwmon_device" in
                "$pwm_device"|"$pwm_device"/*)
                    PWM_RPM_PATH="$candidate"
                    return 0
                    ;;
            esac

            case "$pwm_device" in
                "$hwmon_device"|"$hwmon_device"/*)
                    PWM_RPM_PATH="$candidate"
                    return 0
                    ;;
            esac
        fi

        [ -n "$fallback" ] || fallback="$candidate"
    done

    [ -n "$fallback" ] || return 1
    PWM_RPM_PATH="$fallback"
    return 0
}

find_rpm_candidate_in_dir() {
    base=$1
    candidate=

    [ -n "$base" ] || return 1
    [ -d "$base" ] || return 1

    for candidate in "$base"/fan*_input "$base"/fan*_speed "$base"/fan*_rpm "$base"/rpm; do
        [ -r "$candidate" ] || continue
        printf '%s\n' "$candidate"
        return 0
    done

    return 1
}

resolve_primary_thermal_zone() {
    zone=
    thermal_type=
    fallback_zone=

    [ -d /sys/class/thermal ] || return 1

    for zone in /sys/class/thermal/thermal_zone*; do
        [ -d "$zone" ] || continue
        [ -r "$zone/temp" ] || continue

        thermal_type=$(read_trimmed "$zone/type") || thermal_type=''

        case "$thermal_type" in
            *cpu*|*soc*|*package*)
                printf '%s\n' "${zone##*/}"
                return 0
                ;;
            *)
                [ -n "$fallback_zone" ] || fallback_zone=${zone##*/}
                ;;
        esac
    done

    [ -n "$fallback_zone" ] || return 1
    printf '%s\n' "$fallback_zone"
}

# print: zone trip_point current_target_temp [max_target_temp]
# ex. thermal_zone0 0 50000 60000
get_fan_tp() {
    zone=
    cdev=
    trip=
    temp=
    mintemp=
    mintrip=
    minzone=
    maxtemp=

    [ -d /sys/class/thermal ] || return 1
    cd /sys/class/thermal || return 1

    for zone in thermal_zone*; do
        [ -d "$zone" ] || continue
        cd "$zone" || continue

        for cdev in cdev[0-9]*; do
            case "$cdev" in
                cdev[0-9]*) ;;
                *) continue ;;
            esac

            [ -d "$cdev" ] || continue
            grep -Fiq fan "$cdev/type" || continue

            trip=$(cat "${cdev}_trip_point" 2>/dev/null) || continue
            grep -Fwq active "trip_point_${trip}_type" || continue

            [ -w "trip_point_${trip}_temp" ] || continue
            [ -w "trip_point_${trip}_hyst" ] || continue

            temp=$(cat "trip_point_${trip}_temp" 2>/dev/null) || continue

            if [ -z "$mintemp" ] || [ "$temp" -lt "$mintemp" ]; then
                if [ -n "$mintemp" ]; then
                    if [ "$zone" = "$minzone" ]; then
                        maxtemp=$mintemp
                    else
                        maxtemp=
                    fi
                fi

                mintemp=$temp
                mintrip=$trip
                minzone=$zone
            elif [ -z "$maxtemp" ] || [ "$temp" -lt "$maxtemp" ]; then
                maxtemp=$temp
            fi
        done

        cd /sys/class/thermal || return 1
    done

    if [ -n "$mintemp" ]; then
        echo "$minzone" "$mintrip" "$mintemp" "$maxtemp"
        return 0
    fi

    return 1
}

get_fan_tp_cached() {
    ensure_cache_dir

    if [ -s "$SAVE" ]; then
        cat "$SAVE"
        return 0
    fi

    rm -f "$SAVE"
    get_fan_tp >"$SAVE"
    [ -s "$SAVE" ]
}

get_fan_tp_user() {
    set -- $(get_fan_tp_cached)
    [ -n "$1" ] && [ -n "$2" ] || return 1

    on_temp=$(cat "/sys/class/thermal/$1/trip_point_${2}_temp" 2>/dev/null) || {
        rm -f "$SAVE"
        set -- $(get_fan_tp_cached)
        [ -n "$1" ] && [ -n "$2" ] || return 1
        on_temp=$(cat "/sys/class/thermal/$1/trip_point_${2}_temp" 2>/dev/null) || return 1
    }

    echo "$1" "$2" "$on_temp" "$4"
    return 0
}

init_fan_tp() {
    ensure_cache_dir
    [ -s "$SAVE" ] || get_fan_tp >"$SAVE"
}

resolve_pwm_hwmon() {
    hwmon=
    preferred=
    fallback=
    entry=

    [ -d /sys/class/hwmon ] || return 1

    for hwmon in /sys/class/hwmon/hwmon*; do
        [ -d "$hwmon" ] || continue
        [ -w "$hwmon/pwm1" ] || continue

        name=$(read_trimmed "$hwmon/name") || name=''
        entry="$hwmon|$name"

        case "$name" in
            pwmfan|pwm-fan|pwm_fan)
                preferred=$entry
                break
                ;;
            *)
                [ -n "$fallback" ] || fallback=$entry
                ;;
        esac
    done

    entry=${preferred:-$fallback}
    [ -n "$entry" ] || return 1

    PWM_HWMON=${entry%%|*}
    PWM_NAME=${entry#*|}
    PWM_PATH="$PWM_HWMON/pwm1"
    PWM_ENABLE_PATH=''
    PWM_RPM_PATH=''

    [ -w "$PWM_HWMON/pwm1_enable" ] && PWM_ENABLE_PATH="$PWM_HWMON/pwm1_enable"
    resolve_pwm_rpm_path || true
    return 0
}

resolve_pwm_hwmon_cached() {
    ensure_cache_dir

    if [ -s "$PWM_SAVE" ]; then
        cached=$(cat "$PWM_SAVE" 2>/dev/null)
        PWM_HWMON=${cached%%|*}
        PWM_NAME=${cached#*|}

        if [ -d "$PWM_HWMON" ] && [ -w "$PWM_HWMON/pwm1" ]; then
            PWM_PATH="$PWM_HWMON/pwm1"
            PWM_ENABLE_PATH=''
            PWM_RPM_PATH=''
            [ -w "$PWM_HWMON/pwm1_enable" ] && PWM_ENABLE_PATH="$PWM_HWMON/pwm1_enable"
            resolve_pwm_rpm_path || true
            return 0
        fi
    fi

    resolve_pwm_hwmon || return 1
    printf '%s|%s\n' "$PWM_HWMON" "$PWM_NAME" >"$PWM_SAVE"
    return 0
}

set_pwm_raw() {
    raw=$1
    current_raw=''
    current_enable=''

    is_uint "$raw" || {
        echo 'PWM value must be an unsigned integer' >&2
        return 1
    }

    raw=$(clamp_uint "$raw" 0 255)
    resolve_pwm_hwmon_cached || return 1

    current_raw=$(read_number "$PWM_PATH" 2>/dev/null) || current_raw=''
    [ -n "$PWM_ENABLE_PATH" ] && current_enable=$(read_trimmed "$PWM_ENABLE_PATH" 2>/dev/null) || true

    if [ "$current_raw" = "$raw" ] && { [ -z "$PWM_ENABLE_PATH" ] || [ "$current_enable" = '1' ]; }; then
        return 0
    fi

    if [ -n "$PWM_ENABLE_PATH" ]; then
        # Direct pwm1 writes require manual mode; mode 2 commonly means hardware auto.
        [ "$current_enable" = '1' ] || echo 1 >"$PWM_ENABLE_PATH" 2>/dev/null || true
    fi

    [ "$current_raw" = "$raw" ] || echo "$raw" >"$PWM_PATH"
}

disable_pwm() {
    current_raw=''
    current_enable=''

    resolve_pwm_hwmon_cached || return 0

    current_raw=$(read_number "$PWM_PATH" 2>/dev/null) || current_raw=''
    [ -n "$PWM_ENABLE_PATH" ] && current_enable=$(read_trimmed "$PWM_ENABLE_PATH" 2>/dev/null) || true

    if [ "$current_raw" = '0' ] && { [ -z "$PWM_ENABLE_PATH" ] || [ "$current_enable" = '1' ]; }; then
        return 0
    fi

    if [ -n "$PWM_ENABLE_PATH" ]; then
        [ "$current_enable" = '1' ] || echo 1 >"$PWM_ENABLE_PATH" 2>/dev/null || true
    fi

    [ "$current_raw" = '0' ] || echo 0 >"$PWM_PATH" 2>/dev/null || true
}

get_pwm_status() {
    resolve_pwm_hwmon_cached || return 1

    pwm_raw=$(read_trimmed "$PWM_PATH") || pwm_raw=''
    pwm_enable=''
    pwm_rpm=''

    [ -n "$PWM_ENABLE_PATH" ] && pwm_enable=$(read_trimmed "$PWM_ENABLE_PATH") || true
    [ -n "$PWM_RPM_PATH" ] && pwm_rpm=$(read_trimmed "$PWM_RPM_PATH") || true

    if is_uint "$pwm_raw"; then
        pwm_percent=$(awk -v raw="$pwm_raw" 'BEGIN { printf "%d", int((raw * 100 / 255) + 0.5) }')
    else
        pwm_percent=''
    fi

    printf '%s %s %s %s %s %s\n' "$PWM_HWMON" "$PWM_NAME" "$pwm_raw" "$pwm_percent" "$pwm_enable" "$pwm_rpm"
}

load_trip_defaults() {
    DEFAULT_ON_MILLI=''
    DEFAULT_OFF_MILLI=''
    DEFAULT_NEXT_MILLI=''

    set -- $(get_fan_tp_user 2>/dev/null)
    [ -n "$1" ] && [ -n "$2" ] || return 0

    DEFAULT_ON_MILLI=$3
    DEFAULT_NEXT_MILLI=$4
    hyst=$(read_trimmed "/sys/class/thermal/$1/trip_point_${2}_hyst") || hyst=''
    is_uint "$hyst" || hyst=''

    if [ -n "$DEFAULT_ON_MILLI" ] && [ -n "$hyst" ]; then
        DEFAULT_OFF_MILLI=$((DEFAULT_ON_MILLI - hyst))
    fi
}

# param: ON_TEMP [OFF_TEMP]
# OFF_TEMP = ON_TEMP - 5000 if not set
# ex. 60000 55000
set_fan_tp() {
    on_temp=$1
    off_temp=$2
    current_on=''
    current_hyst=''

    [ -n "$on_temp" ] || {
        echo 'ON_TEMP must be present' >&2
        return 1
    }

    if [ -z "$off_temp" ]; then
        [ "$on_temp" -gt 5000 ] || {
            echo 'ON_TEMP must greater than 5000 when OFF_TEMP not present' >&2
            return 1
        }

        off_temp=$((on_temp - 5000))
    fi

    [ "$on_temp" -gt "$off_temp" ] || {
        echo 'ON_TEMP must greater than OFF_TEMP' >&2
        return 1
    }

    hyst=$((on_temp - off_temp))

    set -- $(get_fan_tp_cached)
    [ -n "$1" ] && [ -n "$2" ] || return 1
    [ -d "/sys/class/thermal/$1" ] || return 1

    if [ -n "$4" ] && [ "$on_temp" -ge "$4" ]; then
        on_temp=$(( $4 - 5000 ))
        echo "WARN: ON_TEMP greater than next TP $4, fixed to $on_temp" >&2
    fi

    current_on=$(read_number "/sys/class/thermal/$1/trip_point_${2}_temp" 2>/dev/null) || current_on=''
    current_hyst=$(read_number "/sys/class/thermal/$1/trip_point_${2}_hyst" 2>/dev/null) || current_hyst=''

    if [ "$current_on" = "$on_temp" ] && [ "$current_hyst" = "$hyst" ]; then
        return 0
    fi

    echo "$on_temp" > "/sys/class/thermal/$1/trip_point_${2}_temp"
    echo "$hyst" > "/sys/class/thermal/$1/trip_point_${2}_hyst"
}

# print: current thermal sensor value and fan on temp
get_temp() {
    resolve_smart_window_milli
    trip_temp=$SMART_WINDOW_ON_MILLI

    zone=$(resolve_primary_thermal_zone 2>/dev/null) || zone=''
    if [ -n "$zone" ] && [ -f "/sys/class/thermal/$zone/temp" ]; then
        temp=$(cat "/sys/class/thermal/$zone/temp" 2>/dev/null) || return 1
        echo "$temp $trip_temp"
        return 0
    fi

    set -- $(get_fan_tp_cached 2>/dev/null)
    if [ -n "$1" ] && [ -n "$2" ] && [ -f "/sys/class/thermal/$1/temp" ]; then
        temp=$(cat "/sys/class/thermal/$1/temp" 2>/dev/null) || return 1
        echo "$temp $trip_temp"
        return 0
    fi

    return 1
}

smart_pwm_raw() {
    temp_milli=$1
    min_milli=${2:-$SMART_MIN_MILLI}
    max_milli=${3:-$SMART_MAX_MILLI}

    awk -v temp="$temp_milli" -v min_temp="$min_milli" -v max_temp="$max_milli" 'BEGIN {
        if (min_temp == "" || min_temp < 0)
            min_temp = 30000
        if (max_temp == "" || max_temp <= min_temp)
            max_temp = min_temp + 30000

        if (temp <= min_temp)
            raw = 0
        else if (temp >= max_temp)
            raw = 255
        else
            raw = int((((temp - min_temp) * 255) / (max_temp - min_temp)) + 0.5)

        if (raw < 0)
            raw = 0
        else if (raw > 255)
            raw = 255

        printf "%d", raw
    }'
}

apply_current_config() {
    enabled=$(uci -q get 'luci-fan.@luci-fan[0].enabled' 2>/dev/null)
    [ "$enabled" = '1' ] || enabled=0

    mode=$(read_uci_mode)
    manual_pwm=$(read_uci_uint manual_pwm) || manual_pwm=70
    interval=$(read_uci_uint poll_interval) || interval=3
    interval=$(clamp_uint "$interval" 1 30)

    if [ "$enabled" != '1' ]; then
        disable_pwm
        return 0
    fi

    resolve_smart_window_milli

    if resolve_pwm_hwmon_cached; then
        case "$mode" in
            turbo)
                set_pwm_raw 255
                return 0
                ;;
            manual)
                raw=$(percent_to_raw "$manual_pwm")
                set_pwm_raw "$raw"
                return 0
                ;;
            *)
                set -- $(get_temp 2>/dev/null)
                temp_milli=$1

                [ -n "$temp_milli" ] || return 1

                raw=$(smart_pwm_raw "$temp_milli" "$SMART_WINDOW_OFF_MILLI" "$SMART_WINDOW_ON_MILLI")
                set_pwm_raw "$raw"
                return 0
                ;;
        esac
    fi

    case "$mode" in
        smart)
            set_fan_tp "$SMART_WINDOW_ON_MILLI" "$SMART_WINDOW_OFF_MILLI"
            ;;
        *)
            return 1
            ;;
    esac
}

print_smart_map() {
    temp_milli=$1
    min_milli=${2:-$SMART_MIN_MILLI}
    max_milli=${3:-$SMART_MAX_MILLI}
    max_rpm=$4

    if ! is_uint "$max_rpm"; then
        resolve_max_rpm
        max_rpm=$EFFECTIVE_MAX_RPM
    else
        max_rpm=$(clamp_uint "$max_rpm" "$SMART_MAX_RPM_MIN" "$SMART_MAX_RPM_MAX")
    fi

    raw=$(smart_pwm_raw "$temp_milli" "$min_milli" "$max_milli") || return 1
    rpm=$(estimate_rpm_from_raw "$raw" "$max_rpm") || return 1
    printf '%s %s\n' "$raw" "$rpm"
}

daemon_loop() {
    interval=5

    while :; do
        apply_current_config
        interval=$(read_uci_uint poll_interval 2>/dev/null) || interval=5
        interval=$(clamp_uint "$interval" 1 30)
        sleep "$interval"
    done
}

usage() {
    echo "usage: $0 sub-command"
    echo 'where sub-command is one of:'
    echo '      get                     Get thermal trip setting'
    echo '      set ON_TEMP [OFF_TEMP]  Set thermal trip setting'
    echo '      temp                    Get current thermal temp and fan start temp'
    echo '      pwm-status              Get detected PWM runtime info'
    echo '      pwm-set RAW             Set PWM duty cycle (0-255)'
    echo '      smart-map TEMP [MIN [MAX [RPM]]]  Print raw PWM and estimated RPM for a temperature in milli-Celsius'
    echo '      apply                   Apply the current UCI profile once'
    echo '      disable                 Stop PWM output if supported'
    echo '      daemon                  Run the smart/manual/turbo control loop'
    echo '      init                    Init caches, internal used'
}

case "$ACTION" in
    get)
        get_fan_tp_user
    ;;
    set)
        set_fan_tp "$@"
    ;;
    temp)
        get_temp
    ;;
    pwm-status)
        get_pwm_status
    ;;
    pwm-set)
        set_pwm_raw "$1"
    ;;
    smart-map)
        print_smart_map "$1" "$2" "$3" "$4"
    ;;
    apply)
        apply_current_config
    ;;
    disable)
        disable_pwm
    ;;
    daemon)
        daemon_loop
    ;;
    init)
        rm -f "$SAVE" "$PWM_SAVE"
        init_fan_tp
        resolve_pwm_hwmon_cached >/dev/null 2>&1 || true
    ;;
    *)
        usage
        exit 1
    ;;
esac

