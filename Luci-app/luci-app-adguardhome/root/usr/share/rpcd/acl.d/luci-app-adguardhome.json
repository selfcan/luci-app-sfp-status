{
	"luci-app-adguardhome": {
		"description": "Grant runtime, UCI and rpcd access for luci-app-adguardhome",
		"read": {
			"uci": [ "AdGuardHome" ],
			"ubus": {
				"luci.adguardhome": [
					"getStatus",
					"getMeta",
					"getTemplateConfig",
					"getYaml",
					"getLog"
				]
			}
		},
		"write": {
			"uci": [ "AdGuardHome" ],
			"ubus": {
				"luci.adguardhome": [
					"saveYaml",
					"discardYaml",
					"clearLog",
					"startUpdate",
					"gfwAction",
					"setLinks"
				]
			}
		}
	}
}